page 90 (
    name: Code-Generator
    alias: GENERATOR
    title: Map Label - Code-Generator
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        fileUrls: #APP_FILES#apex_map_label.js
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            // ===========================================================================
            // Code-Generator: Layer deklarativ im Grid (APEX Collection), Stil je Layer,
            // Live-Preview + generiertes Init-Script.
            // Datenfluss:
            //   Grid (IG) <-> Collection MAPLBL_GEN_LAYERS (C001 Name, C002 Geometrie,
            //   C003 Spalte, C004 Cluster, CLOB001 Stil-JSON)
            //   Selektion -> P90_SEQ_ID -> Stil-Items laden; Item-Änderung -> SAVE_STYLE
            //   Cache (genCache) -> Preview-Instanzen + Code
            // ===========================================================================
            function genNum(id, d) { var v = parseFloat(apex.item(id).getValue()); return isNaN(v) ? d : v; }
            function genStr(id, d) { var v = apex.item(id).getValue(); return v ? v : d; }
            function genYN(id)     { return apex.item(id).getValue() === 'Y'; }
            function genJsLiteral(v) {
              if (typeof v === 'string') { return "'" + v.replace(/\\/g, '\\\\').replace(/'/g, "\\'") + "'"; }
              return JSON.stringify(v);
            }

            window.genCache     = [];   // Zeilen der Collection
            window.genInstances = [];   // apexMapLabel-Controller der Preview

            // ---- Server-Kommunikation -------------------------------------------------
            function genFetchLayers(cb) {
              apex.server.process('GET_LAYERS', {}, { dataType: 'json' }).done(function (data) {
                window.genCache = (data && data.layers ? data.layers : []).map(function (r) {
                  var style = {};
                  try { style = JSON.parse(r.style || '{}'); } catch (e) { style = {}; }
                  return { seqId: String(r.seqId), name: r.name, geomType: r.geomType,
                           colName: r.colName, cluster: r.cluster === 'Y', style: style };
                });
                if (cb) { cb(); }
              });
            }

            function genPersistStyle(seqId, style) {
              apex.server.process('SAVE_STYLE',
                { x01: seqId, x02: JSON.stringify(style) }, { dataType: 'json' });
            }

            // ---- Layer-Typ des ausgewählten Layers --------------------------------------
            function genSelectedGeomType() {
              var row = genRowBySeq(apex.item('P90_SEQ_ID').getValue());
              return row ? row.geomType : 'POINT';
            }

            // Nur die Einstellungen zeigen, die zum Geometrie-Typ passen
            function genUpdateSettingVisibility(geomType) {
              var isLine = geomType === 'LINE';
              var show = function (id, yes) {
                if (yes) { apex.item(id).show(); } else { apex.item(id).hide(); }
              };
              show('P90_PLACEMENT',     isLine);   // line / line-center
              show('P90_POSITION_LINE', isLine);   // über / auf / unter der Linie
              show('P90_POSITION',      !isLine);  // top/bottom/left/right/center
            }

            // ---- Stil <-> Items ---------------------------------------------------------
            function genReadStyle() {
              var always = genYN('P90_ALWAYS');
              var isLine = genSelectedGeomType() === 'LINE';
              var o = {
                placement:       isLine ? genStr('P90_PLACEMENT', 'line') : 'point',
                position:        isLine ? genStr('P90_POSITION_LINE', 'top')
                                        : genStr('P90_POSITION', 'top'),
                offsetPx:        genNum('P90_OFFSET_PX', 16),
                textSize:        genNum('P90_TEXT_SIZE', 12),
                textColor:       genStr('P90_TEXT_COLOR', '#1f2937'),
                haloColor:       genStr('P90_HALO_COLOR', '#ffffff'),
                haloWidth:       genNum('P90_HALO_WIDTH', 2),
                textTransform:   genStr('P90_TEXT_TRANSFORM', 'none'),
                textJustify:     genStr('P90_TEXT_JUSTIFY', 'center'),
                letterSpacing:   genNum('P90_LETTER_SPACING', 0),
                maxWidth:        genNum('P90_MAX_WIDTH', 12),
                minZoom:         genNum('P90_MIN_ZOOM', 0),
                allowOverlap:    always,
                ignorePlacement: always,
                textOptional:    !always,
                hideTooltip:     genYN('P90_HIDE_TOOLTIP'),
                hideInfoWindow:  genYN('P90_HIDE_INFOWINDOW'),
                autoRefresh:     !genYN('P90_NO_AUTO_REFRESH')
              };
              var maxLabels = genNum('P90_MAX_LABELS', 0);
              if (maxLabels > 0) { o.maxLabels = maxLabels; }
              return o;
            }

            function genWriteStyleToItems(style) {
              var d = apexMapLabel.DEFAULTS;
              var s = Object.assign({}, d, style || {});
              // 3. Parameter true = Change-Event unterdruecken (kein Save-Loop!)
              var set = function (id, v) { apex.item(id).setValue(String(v), null, true); };
              set('P90_PLACEMENT',       ['line', 'line-center', 'midpoint'].indexOf(s.placement) >= 0 ? s.placement : 'line');
              set('P90_POSITION',        s.position);
              set('P90_POSITION_LINE',   ['top', 'center', 'bottom'].indexOf(s.position) >= 0 ? s.position : 'top');
              set('P90_OFFSET_PX',       s.offsetPx);
              set('P90_TEXT_SIZE',       s.textSize);
              set('P90_TEXT_COLOR',      s.textColor);
              set('P90_HALO_COLOR',      s.haloColor);
              set('P90_HALO_WIDTH',      s.haloWidth);
              set('P90_TEXT_TRANSFORM',  s.textTransform);
              set('P90_TEXT_JUSTIFY',    s.textJustify);
              set('P90_LETTER_SPACING',  s.letterSpacing);
              set('P90_MAX_WIDTH',       s.maxWidth);
              set('P90_MIN_ZOOM',        s.minZoom);
              set('P90_MAX_LABELS',      s.maxLabels != null ? s.maxLabels : 0);
              set('P90_ALWAYS',          s.allowOverlap ? 'Y' : 'N');
              set('P90_HIDE_TOOLTIP',    s.hideTooltip ? 'Y' : 'N');
              set('P90_HIDE_INFOWINDOW', s.hideInfoWindow ? 'Y' : 'N');
              set('P90_NO_AUTO_REFRESH', s.autoRefresh === false ? 'Y' : 'N');
            }

            // ---- Auswahl / Grid ---------------------------------------------------------
            function genRowBySeq(seqId) {
              return window.genCache.find(function (r) { return r.seqId === String(seqId); }) || null;
            }

            function genSelectLayer(seqId) {
              apex.item('P90_SEQ_ID').setValue(String(seqId), null, true);
              var row = genRowBySeq(seqId);
              if (row) {
                genWriteStyleToItems(row.style);
                genUpdateSettingVisibility(row.geomType);
                // Vorschau auf den selektierten Layer umschalten
                genRenderAll();
              }
            }

            // Vom Selection-Change-Event des Grids aufgerufen
            function genOnGridSelection(model, selectedRecords) {
              if (!model || !selectedRecords || !selectedRecords.length) { return; }
              var seqId = model.getValue(selectedRecords[0], 'SEQ_ID');
              if (seqId != null && seqId !== '') { genSelectLayer(seqId); }
            }

            // ---- Preview ------------------------------------------------------------------
            // Geometrie-Typ -> Demo-Layer der Vorschau-Karte (beide nutzen Spalte NAME)
            function genDemoTarget(geomType) {
              if (geomType === 'LINE') { return { layer: 'Routes', column: 'NAME' }; }
              return { layer: 'Cities', column: 'NAME' };   // POINT + POLYGON (Centroid)
            }

            function genEffectiveStyle(row) {
              var s = Object.assign({}, row.style);
              if (row.geomType === 'LINE' && (!s.placement || s.placement === 'point')) {
                s.placement = 'line';
              }
              if (row.geomType !== 'LINE') { s.placement = 'point'; }
              if (row.cluster) { s.clusterLabel = true; }
              return s;
            }

            function genRefreshPreview() {
              window.genInstances.forEach(function (c) { try { c.destroy(); } catch (e) {} });
              window.genInstances = [];
              var row = genSelectedRow();
              if (!row) { return; }
              var t = genDemoTarget(row.geomType);
              window.genInstances.push(apexMapLabel(Object.assign(
                { regionId: 'MAP_GEN', layerName: t.layer, column: t.column, debug: false },
                genEffectiveStyle(row),
                // In der Vorschau nie das Tooltip-CSS setzen (gilt fuer die Ziel-App)
                { hideTooltip: false, hideInfoWindow: false }
              )));
            }

            // ---- Code-Erzeugung -------------------------------------------------------------
            function genVarName(name) {
              var n = String(name || 'layer').toLowerCase().replace(/\W+/g, '_').replace(/^_+|_+$/g, '');
              return 'lbl_' + (n || 'layer');
            }

            function genClusterFixCode(regionId) {
              return '// Workaround APEX-26.1-Clustering-Bug (siehe README):\n' +
                     '(function armClusterFix() {\n' +
                     '  var r = apex.region(' + genJsLiteral(regionId) + '), m = null;\n' +
                     '  try { m = r && r.call(\'getMapObject\'); } catch (e) {}\n' +
                     '  if (!m) { setTimeout(armClusterFix, 100); return; }\n' +
                     '  apexMapLabel.fixApexClusterSource(m);\n' +
                     '  r.refresh();\n' +
                     '})();\n';
            }

            function genEntryCode(row, regionId) {
              var d    = apexMapLabel.DEFAULTS;
              var all  = genEffectiveStyle(row);
              var keys = ['clusterLabel','placement','position','offsetPx','textSize','textColor',
                          'haloColor','haloWidth','textTransform','textJustify','letterSpacing',
                          'maxWidth','minZoom','maxLabels','allowOverlap','ignorePlacement',
                          'textOptional','hideTooltip','hideInfoWindow','autoRefresh'];
              var rows = [
                '  regionId:  ' + genJsLiteral(regionId),
                '  layerName: ' + genJsLiteral(row.name || 'Layer'),
                '  column:    ' + genJsLiteral(row.colName || 'NAME')
              ];
              keys.forEach(function (k) {
                if (!(k in all)) { return; }
                if (JSON.stringify(all[k]) === JSON.stringify(d[k])) { return; }
                rows.push('  ' + k + ': ' + genJsLiteral(all[k]));
              });
              return 'window.' + genVarName(row.name) + ' = apexMapLabel({\n' + rows.join(',\n') + '\n});';
            }

            function genRenderCode() {
              var regionId = genStr('P90_REGION_ID', 'MY_MAP');
              var code = '';
              if (window.genCache.some(function (r) { return r.cluster; })) {
                code += genClusterFixCode(regionId) + '\n';
              }
              window.genCache.forEach(function (row, idx) {
                if (window.genCache.length > 1) {
                  code += '// ---- Layer ' + (idx + 1) + ': ' + (row.name || '?') +
                          ' (' + row.geomType + (row.cluster ? ', Cluster' : '') + ') ----\n';
                }
                code += genEntryCode(row, regionId) + '\n\n';
              });
              apex.item('P90_CODE').setValue(code.trim() ||
                '-- Noch keine Layer im Grid angelegt --');
            }

            // ---- Nur konfigurierte Layer-Typen auf der Vorschau-Karte zeigen ---------------
            // true = angewendet, false = Legende/Layer existieren noch nicht (Map lädt
            // ihre Layer asynchron NACH dem initialized-Event -> Retry nötig)
            function genSetApexLayerVisible(layerName, visible) {
              try {
                var region = apex.region('MAP_GEN');
                var map    = region.call('getMapObject');
                var info   = (region.layers || []).find(function (l) { return l.name === layerName; });
                if (!info) { return false; }
                var id      = String(info.id);
                var applied = false;
                // Bevorzugt über die Legend-Checkbox togglen (Widget bleibt synchron),
                // sonst direkt am Layer; den Legend-Eintrag zusätzlich ausblenden.
                var cb = document.getElementById(id + '_legend_item_checkbox');
                if (cb) {
                  if (cb.checked !== visible) { cb.click(); }
                  applied = true;
                } else if (map && map.getLayer(id)) {
                  map.setLayoutProperty(id, 'visibility', visible ? 'visible' : 'none');
                  applied = true;
                }
                var li = document.getElementById(id + '_legend_item');
                if (li) { li.style.display = visible ? '' : 'none'; }
                return applied;
              } catch (e) { return false; }
            }

            // Die Vorschau zeigt genau den im Grid SELEKTIERTEN Layer – so lassen
            // sich auch mehrere Layer desselben Typs unabhängig stylen.
            function genSelectedRow() {
              return genRowBySeq(apex.item('P90_SEQ_ID').getValue());
            }

            function genSyncDemoLayers(attempt) {
              attempt = attempt || 0;
              var row    = genSelectedRow();
              var isLine = !!row && row.geomType === 'LINE';
              var ok = genSetApexLayerVisible('Cities', !!row && !isLine);
              ok = genSetApexLayerVisible('Routes', !!row && isLine) && ok;
              if (!ok && attempt < 60) {
                setTimeout(function () { genSyncDemoLayers(attempt + 1); }, 300);
              }
            }

            function genRenderAll() {
              genSyncDemoLayers();
              genRefreshPreview();
              genRenderCode();
            }

            // ---- Aenderung an den Stil-Items ---------------------------------------------
            function genOnStyleChange() {
              var seqId = apex.item('P90_SEQ_ID').getValue();
              var row   = genRowBySeq(seqId);
              if (!row) { return; }
              row.style = genReadStyle();
              genPersistStyle(seqId, row.style);
              genRenderAll();
            }

            // ---- Grid speichern: Model-Changes einsammeln -> Ajax -> Collection ----------
            // Werte defensiv normalisieren: LOV-/Switch-Spalten können Objekte
            // ({v, d}) oder Booleans liefern, neue Zeilen haben Temp-IDs ("t1000").
            function genPlainVal(v, dflt) {
              if (v == null) { return dflt; }
              if (typeof v === 'object') { v = (v.v != null ? v.v : dflt); }
              v = String(v).trim();
              return v || dflt;
            }
            function genPlainYN(v) {
              if (v === true) { return 'Y'; }
              var s = genPlainVal(v, 'N').toUpperCase();
              return (s === 'Y' || s === 'TRUE' || s === '1') ? 'Y' : 'N';
            }

            function genSaveGrid() {
              var model;
              try { model = apex.region('GEN_GRID').call('getViews').grid.model; }
              catch (e) { return; }
              var payload = { rows: [] };
              model.getChanges().forEach(function (ch) {
                var r = ch.record;
                var status = ch.deleted ? 'D' : (ch.inserted ? 'C' : 'U');
                var seqId  = genPlainVal(model.getValue(r, 'SEQ_ID'), '');
                // Geloeschte, nie gespeicherte Zeilen (Temp-ID) gibt es serverseitig nicht
                if (status === 'D' && !/^\d+$/.test(seqId)) { return; }
                payload.rows.push({
                  status:   status,
                  seqId:    /^\d+$/.test(seqId) ? seqId : null,
                  name:     genPlainVal(model.getValue(r, 'LAYER_NAME'), 'Layer'),
                  geomType: genPlainVal(model.getValue(r, 'GEOM_TYPE'), 'POINT'),
                  colName:  genPlainVal(model.getValue(r, 'LABEL_COLUMN'), 'NAME'),
                  cluster:  genPlainYN(model.getValue(r, 'CLUSTERING'))
                });
              });
              if (!payload.rows.length) {
                apex.message.showPageSuccess('Keine Änderungen im Grid.');
                return;
              }
              apex.server.process('SAVE_LAYERS',
                { x01: JSON.stringify(payload) }, { dataType: 'json' }
              ).done(function () {
                // Model-Änderungen sind jetzt serverseitig - leeren, sonst
                // warnt der Refresh vor "unsaved changes"
                try { model.clearChanges(); } catch (e) {}
                apex.region('GEN_GRID').refresh();
                genFetchLayers(function () {
                  genRenderAll();
                  apex.item('P90_SEQ_ID').setValue('', null, true);
                  genAutoSelectFirst();
                  apex.message.showPageSuccess('Layer gespeichert.');
                });
              });
            }

            // ---- Grid-Events (DOM-Events des IG, kein Page-Submit noetig) ------------------
            function genHookGrid() {
              var el = document.getElementById('GEN_GRID');
              if (!el || !window.apex || !apex.jQuery) { setTimeout(genHookGrid, 200); return; }
              apex.jQuery(el).on('interactivegridselectionchange', function (ev, ui) {
                genOnGridSelection(ui && ui.model, ui && ui.selectedRecords);
              });
            }

            function genAutoSelectFirst() {
              var sel = apex.item('P90_SEQ_ID').getValue();
              if (sel && genRowBySeq(sel)) { return; }
              if (!window.genCache.length) { return; }
              genSelectLayer(window.genCache[0].seqId);
              try {
                var grid = apex.region('GEN_GRID').call('getViews').grid;
                var rec  = grid.model.recordAt(0);
                if (rec) { grid.setSelectedRecords([rec]); }
              } catch (e) { /* Grid noch nicht bereit - Items sind gesetzt */ }
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region intro (
        name: Was macht diese Seite
        type: staticContent
        source {
            htmlCode:
                ```html
                <p><strong>1.</strong> Map-Region konfigurieren → <strong>2.</strong> Layer
                deklarativ im Grid anlegen (Name, Geometrie-Typ wie in der APEX-Map-Region,
                Label-Spalte, Clustering) und <strong>speichern</strong> →
                <strong>3.</strong> Layer im Grid anklicken und seine Label-Einstellungen
                darunter feinjustieren (werden automatisch je Layer gespeichert) →
                <strong>4.</strong> Die Vorschau-Karte zeigt genau den <strong>selektierten</strong>
                Layer – so lassen sich auch mehrere Layer desselben Typs unabhängig stylen.
                Das Init-Script unten enthält immer <strong>alle</strong> Layer. Neue Layer
                starten mit Default-Einstellungen und sind sofort sichtbar.</p>
                ```
        }
        layout {
            sequence: 5
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    region target (
        name: 1. Ziel-Map-Region
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    pageItem P90_REGION_ID (
        type: textField
        label {
            label: Static ID der Map-Region in der Ziel-App
        }
        layout {
            sequence: 10
            region: @target
            slot: regionBody
        }
        appearance {
            template: @/optional-floating
        }
    )

    pageItem P90_SEQ_ID (
        type: hidden
        layout {
            sequence: 20
            region: @target
            slot: regionBody
        }
    )

    region gen-grid (
        name: 2. Layer (deklarativ, wie in der Ziel-Map-Region)
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select seq_id,
                       c001 as layer_name,
                       c002 as geom_type,
                       c003 as label_column,
                       c004 as clustering
                  from apex_collections
                 where collection_name = 'MAPLBL_GEN_LAYERS'
                 order by seq_id
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: GEN_GRID
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }

        savedReport PRIMARY (
            visibility: primary
            view {
                default: grid
            }

            displayColumn (
                column: @LAYER_NAME
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @GEOM_TYPE
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @LABEL_COLUMN
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @CLUSTERING
                layout {
                    sequence: 4
                }
            )

        )

        column SEQ_ID (
            type: hidden
            layout {
                sequence: 10
            }
            source {
                databaseColumn: SEQ_ID
                dataType: number
                primaryKey: true
            }
        )

        column LAYER_NAME (
            type: textField
            heading {
                heading: Layer-Name (case-sensitive)
            }
            layout {
                sequence: 20
            }
            validation {
                maxLength: 200
            }
            source {
                databaseColumn: LAYER_NAME
                dataType: varchar2
            }
        )

        column GEOM_TYPE (
            type: selectList
            heading {
                heading: Geometrie-Typ
            }
            layout {
                sequence: 30
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 'Punkte' as d, 'POINT' as r from dual
                    union all select 'Linien', 'LINE' from dual
                    union all select 'Polygone', 'POLYGON' from dual
                    ```
                displayNullValue: false
            }
            source {
                databaseColumn: GEOM_TYPE
                dataType: varchar2
            }
        )

        column LABEL_COLUMN (
            type: textField
            heading {
                heading: Label-Spalte (Tooltip-Spalte!)
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 128
            }
            source {
                databaseColumn: LABEL_COLUMN
                dataType: varchar2
            }
        )

        column CLUSTERING (
            type: switch
            heading {
                heading: Clustering
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: CLUSTERING
                dataType: varchar2
            }
        )

    )

    button save-layers (
        buttonName: SAVE_LAYERS_BTN
        label: Layer speichern
        layout {
            sequence: 10
            region: @gen-grid
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            icon: fa-save
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    region controls (
        name: 3. Label-Einstellungen des ausgewählten Layers
        type: staticContent
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    pageItem P90_PLACEMENT (
        type: selectList
        label {
            label: Linien-Placement
        }
        layout {
            sequence: 10
            region: @controls
            slot: regionBody
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Line (wiederholt entlang der Linie)' as d, 'line' as r from dual
                union all select 'Line-Center (einmal, auf der Linie)', 'line-center' from dual
                union all select 'Midpoint (horizontal, immer sichtbar)', 'midpoint' from dual
                ```
            displayNullValue: false
        }
    )

    pageItem P90_POSITION_LINE (
        type: selectList
        label {
            label: Position zur Linie
        }
        layout {
            sequence: 15
            region: @controls
            slot: regionBody
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Über der Linie' as d, 'top' as r from dual
                union all select 'Auf der Linie', 'center' from dual
                union all select 'Unter der Linie', 'bottom' from dual
                ```
            displayNullValue: false
        }
    )

    pageItem P90_POSITION (
        type: selectList
        label {
            label: Position
        }
        layout {
            sequence: 20
            region: @controls
            slot: regionBody
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Top' as d, 'top' as r from dual
                union all select 'Bottom', 'bottom' from dual
                union all select 'Left', 'left' from dual
                union all select 'Right', 'right' from dual
                union all select 'Center', 'center' from dual
                ```
            displayNullValue: false
        }
    )

    pageItem P90_OFFSET_PX (
        type: numberField
        label {
            label: Offset (px)
        }
        layout {
            sequence: 30
            region: @controls
            slot: regionBody
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
        }
    )

    pageItem P90_ALWAYS (
        type: selectList
        label {
            label: Immer anzeigen
        }
        layout {
            sequence: 40
            region: @controls
            slot: regionBody
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Nein (Kollisionen vermeiden)' as d, 'N' as r from dual
                union all select 'Ja (Overlap erlauben)', 'Y' from dual
                ```
            displayNullValue: false
