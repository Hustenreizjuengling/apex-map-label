    pageItem P90_CODE (
        type: textarea
        label {
            label: Kompletter Code für die "Map Initialized"-Dynamic-Action der Ziel-App
        }
        layout {
            sequence: 10
            region: @output
            slot: regionBody
        }
        appearance {
            template: @/optional-floating
            height: 16
        }
        settings {
            resizable: true
        }
    )

    region howto (
        name: Einbau-Anleitung für die Ziel-Applikation
        type: staticContent
        source {
            htmlCode:
                ```html
                <ol>
                  <li><strong>Library hochladen:</strong> <code>apex_map_label.js</code> in der
                      Ziel-App unter <em>Shared Components → Static Application Files</em>
                      hochladen (Datei aus diesem Repo: <code>src/apex_map_label.js</code>).</li>
                  <li><strong>Einbinden:</strong> Auf der Seite mit der Map unter
                      <em>Page Properties → JavaScript → File URLs</em> eintragen:
                      <code>&#35;APP_FILES&#35;apex_map_label.js</code></li>
                  <li><strong>Map vorbereiten:</strong> Der Map-Region eine
                      <em>Static ID</em> geben und in <strong>jedem</strong> zu beschriftenden
                      Layer die Label-Spalte als <em>Tooltip-Spalte</em> konfigurieren –
                      sonst kommt der Wert nicht am Client an. Layer-Namen und Geometrie-Typen
                      müssen dem Grid oben entsprechen.</li>
                  <li><strong>Dynamic Action anlegen:</strong> Auf der Map-Region, Event
                      <em>Map Initialized [Map]</em>, Selection Type <em>Region</em>,
                      True Action <em>Execute JavaScript Code</em> – und das komplette
                      generierte Script von oben einfügen (ein Block je Layer,
                      alles in EINE Action).</li>
                  <li><strong>Fertig.</strong> Labels erscheinen nach dem Map-Load; bei
                      Region-Refreshes aktualisieren sie sich automatisch
                      (<code>autoRefresh</code> ist Default).</li>
                </ol>
                <p><strong>Hinweis zur Vorschau:</strong> Gezeigt wird immer der im Grid
                selektierte Layer – Punkte/Polygone auf dem Punkte-Demo-Layer (Polygone werden
                am Centroid beschriftet), Linien auf dem Linien-Demo-Layer. Das Init-Script
                enthält unabhängig davon alle Layer. Die Layer-Liste bleibt für die Dauer der
                APEX-Session erhalten (APEX Collection).</p>
                ```
        }
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    process ensure-collection (
        name: Ensure layer collection
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  if not apex_collection.collection_exists('MAPLBL_GEN_LAYERS') then
                    apex_collection.create_collection('MAPLBL_GEN_LAYERS');
                    -- Start-Layer mit Default-Einstellungen, damit sofort etwas sichtbar ist
                    apex_collection.add_member(
                      p_collection_name => 'MAPLBL_GEN_LAYERS',
                      p_c001            => 'Stations',
                      p_c002            => 'POINT',
                      p_c003            => 'NAME',
                      p_c004            => 'N',
                      p_clob001         => to_clob('{}'));
                  end if;
                  :P90_REGION_ID := coalesce(:P90_REGION_ID, 'MY_MAP');
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    process save-layers (
        name: SAVE_LAYERS
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_values apex_json.t_values;
                  l_cnt    pls_integer;
                  l_status varchar2(1);
                  l_seq    varchar2(40);
                begin
                  apex_json.parse(l_values, apex_application.g_x01);
                  l_cnt := apex_json.get_count(p_path => 'rows', p_values => l_values);
                  for i in 1 .. nvl(l_cnt, 0) loop
                    l_status := apex_json.get_varchar2(p_path => 'rows[%d].status', p0 => i, p_values => l_values);
                    l_seq    := apex_json.get_varchar2(p_path => 'rows[%d].seqId',  p0 => i, p_values => l_values);
                    -- Temp-IDs neuer Grid-Zeilen ("t1000") sind keine Collection-Seqs
                    if l_status in ('U', 'D')
                       and to_number(l_seq default null on conversion error) is null then
                      continue;
                    end if;
                    case l_status
                      when 'C' then
                        apex_collection.add_member(
                          p_collection_name => 'MAPLBL_GEN_LAYERS',
                          p_c001    => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].name',     p0 => i, p_values => l_values), 'Layer'),
                          p_c002    => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].geomType', p0 => i, p_values => l_values), 'POINT'),
                          p_c003    => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].colName',  p0 => i, p_values => l_values), 'NAME'),
                          p_c004    => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].cluster',  p0 => i, p_values => l_values), 'N'),
                          p_clob001 => to_clob('{}'));
                      when 'U' then
                        apex_collection.update_member_attribute(
                          p_collection_name => 'MAPLBL_GEN_LAYERS',
                          p_seq             => to_number(l_seq),
                          p_attr_number     => 1,
                          p_attr_value      => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].name',     p0 => i, p_values => l_values), 'Layer'));
                        apex_collection.update_member_attribute(
                          p_collection_name => 'MAPLBL_GEN_LAYERS',
                          p_seq             => to_number(l_seq),
                          p_attr_number     => 2,
                          p_attr_value      => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].geomType', p0 => i, p_values => l_values), 'POINT'));
                        apex_collection.update_member_attribute(
                          p_collection_name => 'MAPLBL_GEN_LAYERS',
                          p_seq             => to_number(l_seq),
                          p_attr_number     => 3,
                          p_attr_value      => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].colName',  p0 => i, p_values => l_values), 'NAME'));
                        apex_collection.update_member_attribute(
                          p_collection_name => 'MAPLBL_GEN_LAYERS',
                          p_seq             => to_number(l_seq),
                          p_attr_number     => 4,
                          p_attr_value      => coalesce(apex_json.get_varchar2(p_path => 'rows[%d].cluster',  p0 => i, p_values => l_values), 'N'));
                      when 'D' then
                        apex_collection.delete_member(
                          p_collection_name => 'MAPLBL_GEN_LAYERS',
                          p_seq             => to_number(l_seq));
                      else
                        null;
                    end case;
                  end loop;
                  apex_json.open_object;
                  apex_json.write('ok', true);
                  apex_json.close_object;
                exception
                  when others then
                    apex_json.open_object;
                    apex_json.write('ok', false);
                    apex_json.write('error', substr(sqlerrm, 1, 500));
                    apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 15
            point: ajaxCallback
        }
    )

    process get-layers (
        name: GET_LAYERS
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  apex_json.open_object;
                  apex_json.open_array('layers');
                  for r in (select seq_id, c001, c002, c003, c004, clob001
                              from apex_collections
                             where collection_name = 'MAPLBL_GEN_LAYERS'
                             order by seq_id) loop
                    apex_json.open_object;
                    apex_json.write('seqId',    r.seq_id);
                    apex_json.write('name',     r.c001);
                    apex_json.write('geomType', r.c002);
                    apex_json.write('colName',  r.c003);
                    apex_json.write('cluster',  r.c004);
                    apex_json.write('style',    r.clob001);
                    apex_json.close_object;
                  end loop;
                  apex_json.close_array;
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 20
            point: ajaxCallback
        }
    )

    process save-style (
        name: SAVE_STYLE
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  apex_collection.update_member_attribute(
                    p_collection_name => 'MAPLBL_GEN_LAYERS',
                    p_seq             => to_number(apex_application.g_x01),
                    p_clob_number     => 1,
                    p_clob_value      => to_clob(apex_application.g_x02));
                  apex_json.open_object;
                  apex_json.write('ok', true);
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 30
            point: ajaxCallback
        }
    )

    dynamicAction da-init (
        name: Init generator
        execution {
            sequence: 10
        }
        when {
            event: region/map/spatialmapinitialized
            selectionType: region
            region: @map-gen
        }

        action init-generator (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    genHookGrid();
                    genUpdateSettingVisibility('POINT');
                    genFetchLayers(function () {
                      genRenderAll();
                      genAutoSelectFirst();
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction da-style-change (
        name: Style geändert - speichern und anwenden
        execution {
            sequence: 20
        }
        when {
            event: change
            selectionType: items
            items: P90_PLACEMENT,P90_POSITION,P90_POSITION_LINE,P90_OFFSET_PX,P90_ALWAYS,P90_TEXT_SIZE,P90_TEXT_COLOR,P90_HALO_COLOR,P90_HALO_WIDTH,P90_TEXT_TRANSFORM,P90_TEXT_JUSTIFY,P90_LETTER_SPACING,P90_MAX_WIDTH,P90_MIN_ZOOM,P90_MAX_LABELS,P90_HIDE_TOOLTIP,P90_HIDE_INFOWINDOW,P90_NO_AUTO_REFRESH
        }

        action apply-style (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    genOnStyleChange();
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction da-save-grid (
        name: Grid speichern
        execution {
            sequence: 25
        }
        when {
            event: click
            selectionType: button
            button: @save-layers
        }

        action save-grid-action (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    genSaveGrid();
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction da-region-change (
        name: Region-ID geändert - Code neu
        execution {
            sequence: 30
        }
        when {
            event: change
            selectionType: items
            items: P90_REGION_ID
        }

        action rerender-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    genRenderCode();
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)
