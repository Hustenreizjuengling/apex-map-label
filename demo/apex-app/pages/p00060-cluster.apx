        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: MAP_CL
        }
        controls {
            options: [
                mousewheelZoom
                scaleBar
            ]
        }
        initialPositionAndZoom {
            type: staticValues
            latitude: 50.9
            longitude: 8.5
            zoomLevel: 6
        }

        layer stations (
            name: Stations
            label {
                label: Stations
            }
            layout {
                sequence: 10
            }
            source {
                location: regionSource
            }
            columnMapping {
                geometryColumnDataType: geojson
                geojsonColumn: GEOJSON
                primaryKeyColumn: ID
            }
            pointObjects {
                style: icon
                iconSource: iconClass
                iconCssClasses: fa-map-marker
            }
            pointClustering {
                enable: true
                iconCssClasses: fa-circle-o
            }
            appearance {
                fillColor: #2563eb
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &NAME.
            }
        )

    )

    process set-defaults (
        name: Set control defaults
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  :P60_CLUSTER_FORMAT := coalesce(:P60_CLUSTER_FORMAT, 'COUNT');
                  :P60_POSITION       := coalesce(:P60_POSITION, 'top');
                  :P60_OFFSET_PX      := coalesce(:P60_OFFSET_PX, '14');
                  :P60_ALLOW_OVERLAP  := coalesce(:P60_ALLOW_OVERLAP, 'N');
                  :P60_TEXT_SIZE      := coalesce(:P60_TEXT_SIZE, '13');
                  :P60_TEXT_COLOR     := coalesce(:P60_TEXT_COLOR, '#1f2937');
                  :P60_HALO_COLOR     := coalesce(:P60_HALO_COLOR, '#ffffff');
                  :P60_HALO_WIDTH     := coalesce(:P60_HALO_WIDTH, '2');
                  :P60_TEXT_TRANSFORM := coalesce(:P60_TEXT_TRANSFORM, 'none');
                  :P60_LETTER_SPACING := coalesce(:P60_LETTER_SPACING, '0');
                  :P60_MAX_WIDTH      := coalesce(:P60_MAX_WIDTH, '12');
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    dynamicAction da-init (
        name: Init labels
        execution {
            sequence: 10
        }
        when {
            event: region/map/spatialmapinitialized
            selectionType: region
            region: @map-cl
        }

        action init-label (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Workaround APEX-26.1-Bug: Clustering-Source wird von MapLibre
                    // abgelehnt ("cluster: boolean expected"). Patchen + Region neu
                    // laden, dann wartet apexMapLabel event-getrieben auf den Layer.
                    // getMapObject ist beim DA-Zeitpunkt evtl. noch null -> Retry.
                    (function armClusterFix() {
                      var r = apex.region('MAP_CL'), m = null;
                      try { m = r && r.call('getMapObject'); } catch (e) { /* noch nicht bereit */ }
                      if (!m) { setTimeout(armClusterFix, 100); return; }
                      apexMapLabel.fixApexClusterSource(m);
                      r.refresh();
                    })();

                    window.clLabels = apexMapLabel(Object.assign(
                      { regionId: 'MAP_CL', layerName: 'Stations', column: 'NAME', hideTooltip: true, debug: true },
                      clReadOpts()
                    ));
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction da-apply (
        name: Apply options
        execution {
            sequence: 20
        }
        when {
            event: change
            selectionType: items
            items: P60_CLUSTER_FORMAT,P60_POSITION,P60_OFFSET_PX,P60_ALLOW_OVERLAP,P60_TEXT_SIZE,P60_TEXT_COLOR,P60_HALO_COLOR,P60_HALO_WIDTH,P60_TEXT_TRANSFORM,P60_LETTER_SPACING,P60_MAX_WIDTH
        }

        action apply-label (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    if (window.clLabels) { window.clLabels.setOptions(clReadOpts()); }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)
