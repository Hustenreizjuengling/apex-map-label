page 60 (
    name: Cluster
    alias: CLUSTER
    title: Map Label - Cluster
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        fileUrls: #APP_FILES#apex_map_label.js
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            // Liest die Steuer-Items der Cluster-Seite und baut das Options-Objekt.
            function clReadOpts() {
              var num = function (id, d) { var v = parseFloat(apex.item(id).getValue()); return isNaN(v) ? d : v; };
              var str = function (id, d) { var v = apex.item(id).getValue(); return v ? v : d; };
              var mode = apex.item('P60_CLUSTER_FORMAT').getValue() || 'COUNT';
              var clusterLabel = false;
              if (mode === 'COUNT') { clusterLabel = true; }
              else if (mode === 'TEXT') {
                clusterLabel = function (f) { return f.properties.point_count + ' Orte'; };
              }
              return {
                clusterLabel:  clusterLabel,
                position:      str('P60_POSITION', 'top'),
                offsetPx:      num('P60_OFFSET_PX', 14),
                textSize:      num('P60_TEXT_SIZE', 13),
                textColor:     str('P60_TEXT_COLOR', '#1f2937'),
                haloColor:     str('P60_HALO_COLOR', '#ffffff'),
                haloWidth:     num('P60_HALO_WIDTH', 2),
                textTransform: str('P60_TEXT_TRANSFORM', 'none'),
                letterSpacing: num('P60_LETTER_SPACING', 0),
                maxWidth:      num('P60_MAX_WIDTH', 12),
                allowOverlap:  apex.item('P60_ALLOW_OVERLAP').getValue() === 'Y'
              };
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region info (
        name: Was zeigt diese Seite
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Der Layer hat <strong>Point Clustering</strong> aktiviert. Mit
                <code>clusterLabel</code> beschriftet apex-map-label die Cluster – wahlweise mit
                der Punktanzahl (<code>true</code>) oder per eigener Format-Funktion
                (z. B. "12 Orte"). Einzelpunkte bekommen weiterhin ihr normales Label.
                Heraus- und hineinzoomen, um Cluster entstehen und zerfallen zu sehen.</p>
                <p><strong>Hinweis:</strong> APEX 26.1 hat einen Bug, durch den Cluster-Layer gar
                nicht erst gerendert werden (MapLibre lehnt die Source ab: "cluster: boolean
                expected, object found"). Diese Seite nutzt den Workaround
                <code>apexMapLabel.fixApexClusterSource(map)</code> + Region-Refresh.</p>
                ```
        }
        layout {
            sequence: 5
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    region controls (
        name: Einstellungen
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    pageItem P60_CLUSTER_FORMAT (
        type: selectList
        label {
            label: Cluster labels
        }
        layout {
            sequence: 10
            region: @controls
            slot: regionBody
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Anzahl (point_count)' as d, 'COUNT' as r from dual
                union all select 'Eigenes Format ("N Orte")', 'TEXT' from dual
                union all select 'Aus (Cluster ohne Label)', 'OFF' from dual
                ```
            displayNullValue: false
        }
    )

    pageItem P60_POSITION (
        type: selectList
        label {
            label: Position
        }
        layout {
            sequence: 20
            region: @controls
            slot: regionBody
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Top' as d, 'top' as r from dual
                union all select 'Bottom', 'bottom' from dual
                union all select 'Left', 'left' from dual
                union all select 'Right', 'right' from dual
                union all select 'Center', 'center' from dual
                ```
            displayNullValue: false
